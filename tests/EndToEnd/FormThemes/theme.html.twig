{% use 'form_div_layout.html.twig' %}

{%- block form_start -%}
    {%- set attr = attr|merge({ 'data-controller': ('form ' ~ attr['data-controller']|default(''))|trim }) -%}
    {{- parent() -}}
{%- endblock form_start -%}

{%- block form_widget_simple -%}
    {% assert_type form 'Symfony\\Component\\Form\\FormView' %}
    {% assert_type errors 'Symfony\\Component\\Form\\FormErrorIterator<Symfony\\Component\\Form\\FormError>' %}
    {% assert_type required 'bool' %}
    {%- set attr = attr|merge({ class: ('input ' ~ attr.class|default(''))|trim }) -%}
    {{- parent() -}}
{%- endblock form_widget_simple -%}

{%- block form_label -%}
    {%- if label is not same as(false) -%}
        {%- set label_attr = label_attr|merge({ class: ('label ' ~ label_attr.class|default(''))|trim }) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock form_label -%}

{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul>
            {%- for error in errors -%}
                <li id="{{ id ~ '_error' ~ loop.index }}">{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{%- endblock form_errors -%}

{%- block form_help -%}
    {# Deliberate bug: `lable` does not exist, the analysis must keep flagging it. #}
    {%- if help is not empty -%}
        <p title="{{ lable }}" id="{{ id }}_help"></p>
    {%- endif -%}
{%- endblock form_help -%}

{# The base theme's form_row sets widget_attr before dispatching here. #}
{%- block form_row_render -%}
    <div{% with { attr: row_attr } %}{{ block('attributes') }}{% endwith %}>
        {{- form_label(form) -}}
        {{- form_errors(form) -}}
        {{- form_widget(form, widget_attr) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock form_row_render -%}

{%- block submit_widget -%}
    {%- set type = type|default('submit') -%}
    {{- block('button_widget') -}}
{%- endblock submit_widget -%}

{%- block button_widget -%}
    {%- set attr = attr|merge({ class: ('btn ' ~ attr.class|default(''))|trim }) -%}
    {{- parent() -}}
{%- endblock button_widget -%}
